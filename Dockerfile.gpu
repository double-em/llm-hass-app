# syntax=docker/dockerfile:1

# ============================================================================
# GPU Build stage
# ============================================================================
FROM nvidia/cuda:12.4.0-devel-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /build

# Install Python 3.12 from deadsnakes PPA
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    python3.12 \
    python3.12-venv \
    python3.12-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Create venv
RUN python3.12 -m venv /venv

# Pre-copy requirements for better layer caching
COPY requirements.txt .

# Install PyTorch with CUDA support
RUN /venv/bin/pip install --no-cache-dir torch==2.5.0 torchaudio==2.5.0 --no-warn-script-location

# Install remaining dependencies
RUN /venv/bin/pip install --no-cache-dir -r requirements.txt --no-warn-script-location \
    --ignore-installed torch

# ============================================================================
# GPU Runtime stage
# ============================================================================
FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04 AS runtime

# Build arguments
ARG VERSION=unknown

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PORT=8000
ENV PATH=/venv/bin:$PATH
ENV PYTHONPATH=/app

# Install only runtime Python dependencies (no dev tools, no PPA)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy venv from builder — only runtime-needed artifacts
COPY --from=builder /venv /venv

# Labels
LABEL org.opencontainers.image.title="LLM AI Dashboard (GPU)"
LABEL org.opencontainers.image.description="AI Provider management, voice cloning, TTS, and AI memory (CUDA-enabled)"
LABEL org.opencontainers.image.source="https://github.com/double-em/llm-hass-app"
LABEL org.opencontainers.image.version="${VERSION}"

# Create app directory
WORKDIR /app

# Copy application files
COPY *.py /app/
COPY memory/ /app/memory/
COPY templates/ /app/templates/

# Create data directory
RUN mkdir -p /data/voices /data/persons /data/samples /data/memory

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app /data
USER appuser

EXPOSE 8000

# Health check - socket only, no extra imports
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD python -c "import socket; s=socket.socket(); s.connect(('localhost',8000)); s.close()" || exit 1

CMD ["python", "app.py"]
